      "writtenOn": "2025-12-13T01:29:09Z",
      "side": 1,
      "message": "This scares me a bit.  Do we really want LLDP in this probe?  This seems like something we could just encapsulate entirely within the application?",
      "range": {
        "startLine": 13,
        "startChar": 0,
        "endLine": 13,
        "endChar": 132
      },
      "revId": "59e967528a781ca4e1dd19552294f88370e3a6db",
