{
    "$schema1": "http://json-schema.org/draft-07/schema#",
    "$defs": {
        "ModbusRTUDevice": {
            "description": "The definition for the modbus device.",
            "type": "object",
            "additionalProperties": false,
            "properties": {
                "Type": {
                    "description": "The type of configuration object.",
                    "enum": [
                        "Artesyn7000555240000PowerMonitorModule",
                        "Artesyn7000552480000PowerSupplyUnit",
                        "Artesyn7000552531000PowerShelf",
                        "BelimoEV200ARXEValve",
                        "Danfoss003Z8540Valve",
                        "DeltaBBUBC100AE000PowerMonitorModule",
                        "DeltaBBUBS723AE000PowerShelf",
                        "DeltaBBUBU123AE000BatteryBackupUnit",
                        "DeltaECD17020037PowerSupplyUnit",
                        "DeltaECD27010006CapacitorBankUnit",
                        "DeltaECD68000047PowerShelf",
                        "DeltaECD68000049PowerShelf",
                        "DeltaECD70000017PowerMonitorModule",
                        "DeltaECD70000020PowerMonitorModule",
                        "DeltaRDF040DSS5193E0HeatExchanger",
                        "DeltaRDF040DSS5193E0ReservoirPumpUnit",
                        "PanasonicBJA3C0002ABatteryBackupUnit",
                        "PanasonicBJBSB103APowerShelf",
                        "PanasonicBJBPM103APowerMonitorModule"
                    ]
                },
                "Name": {
                    "description": "The name of the modbus device.",
                    "type": "string"
                },
                "Address": {
                    "description": "The address of the modbus device.",
                    "type": "string"
                },
                "SerialPort": {
                    "description": "The name of the serial port where the device is connected.",
                    "type": "string"
                },
                "PollRate": {
                    "$ref": "legacy.json#/$defs/Types/PollRate"
                },
                "RegisterPollRates": {
                    "description": "The per-register poll rate, as some registers may need to be polled at a different cadence than the device PollRate.",
                    "type": "array",
                    "items": {
                        "type": "object",
                        "additionalProperties": false,
                        "properties": {
                            "Name": {
                                "description": "The name of the register.",
                                "type": "string"
                            },
                            "PollRate": {
                                "description": "The poll rate for the register.",
                                "$ref": "legacy.json#/$defs/Types/PollRate"
                            }
                        },
                        "required": ["Name", "PollRate"]
                    }
                }
            },
            "required": ["Name", "Type", "Address", "SerialPort"]
        }
    }
}
