{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "$defs": {
        "AnalogValve": {
            "description": "The definition for the analog valve for liquid cooling",
            "type": "object",
            "additionalProperties": false,
            "properties": {
                "Name": {
                    "description": "The name of the analog valve.",
                    "type": "string"
                },
                "Type": {
                    "description": "The type of configuration object",
                    "const": "AnalogValve"
                },
                "MaxFlowRate": {
                    "description": "The maximum flow rate supported by the analog valve.",
                    "type": "number"
                },
                "SetPointVoltageRange": {
                    "description": "The voltage range [min, max] for the valve setpoint.",
                    "type": "array",
                    "prefixItems": [
                        {
                            "description": "The minimum voltage for analog valve setpoint",
                            "type": "number"
                        },
                        {
                            "description": "The maximum voltage for analog valve setpoint",
                            "type": "number"
                        }
                    ],
                    "minItems": 2,
                    "maxItems": 2
                },
                "FeedbackADC": {
                    "description": "The ADC used to read valve feedback.",
                    "$ref": "legacy.json#/$defs/ADC"
                },
                "SetPointDAC": {
                    "description": "The DAC used to output the valve setpoint voltage.",
                    "$ref": "legacy.json#/$defs/DAC"
                },
                "Tolerance": {
                    "description": "The acceptable voltage deviation between setpoint and feedback before the valve is considered out of position.",
                    "type": "number"
                }
            },
            "required": [
                "Name",
                "Type",
                "MaxFlowRate",
                "SetPointVoltageRange",
                "FeedbackADC",
                "SetPointDAC",
                "Tolerance"
            ]
        },
        "GPIOValve": {
            "additionalProperties": false,
            "description": "Configuration for GPIO based Valve.",
            "type": "object",
            "properties": {
                "Name": {
                    "description": "The name of the valve.",
                    "type": "string"
                },
                "Type": {
                    "description": "The type of configuration object",
                    "const": "GPIOValve"
                },
                "OpenPinName": {
                    "description": "The name of the GPIO pin that shows the valve's open status.",
                    "type": "string"
                },
                "OpenPolarity": {
                    "description": "The GPIO polarity depicting valve's open status.",
                    "$ref": "legacy.json#/$defs/Types/Polarity"
                },
                "OpenControlPinName": {
                    "description": "The name of the GPIO pin that controls opening the valve.",
                    "type": "string"
                },
                "OpenControlValue": {
                    "description": "The GPIO value to set to open the valve.",
                    "type": "boolean"
                },
                "CoolantLoopName": {
                    "description": "The name of the coolant loop to which this valve is connected.",
                    "type": "string"
                }
            },
            "required": [
                "Name",
                "Type",
                "OpenPinName",
                "OpenPolarity",
                "OpenControlPinName",
                "OpenControlValue",
                "CoolantLoopName"
            ]
        }
    }
}
